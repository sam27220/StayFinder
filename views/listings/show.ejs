<% layout("/layouts/boilerplate.ejs") %>

  
  <body>
    <div class="row">
      <div class="col-8 offset-2 mt-3">
        <h2>
          <%= listing.title %>
        </h2>
      </div>
      <div class="card col-8 offset-2  listing-card">
        <img src="<%=listing.image.url %>" class="card-img-top show-img" alt="listing_img">
        <div class="full-body">
          <div class="card-body">
            <p class="card-text">Owned by : <%= listing.owner.username %>
            </p>
            <p class="card-text">
              <%= listing.description %>
            </p>
            <p class="card-text">&#8377; <%= listing.price.toLocaleString("en-IN") %>
            </p>
            <p class="card-text">
              <%= listing.location %>
            </p>
            <p class="card-text">
              <%= listing.country %>
            </p>
          </div>
          <div class="card-body">

            <div class="price">
              <%= listing.price.toLocaleString("en-IN") %> <span
                  style="font-weight:normal; font-size:16px;">/night</span>
            </div>

            <div class="grid">
              <div class="row">
                <div class="cell">
                  <div class="label">Check-in</div>
                  <input type="date" id="checkin" class="value">
                </div>
                <div class="cell">
                  <div class="label">Checkout</div>
                  <input type="date" id="checkout" class="value">
                </div>
              </div>
            </div>
            <% if(currUser) { %>
            <button id="payBtn" class="btn btn-card">Booking</button>
            <% } else { %>
            <p class="note">Login for Booking</p>
            <% } %>
          </div>
        </div>

        <% if(currUser && currUser._id.equals(listing.owner._id )) { %>
          <div class="card-body-botton mt-3">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-danger">Edit</a>
            <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
              <button class="btn btn-dark">Delete</button>
            </form>
          </div>
          <% } %>

      </div>
    </div>

    <div class="col-8 offset-2 mb-3">
      <% if(currUser) { %>
        <hr>
        <h3>Leave a Review</h3>
        <form method="POST" action="/listings/<%=listing._id %>/reviews" class="needs-validation" novalidate>


          <div class="mb-3 mt-3">
            <label for="rating" class="form-label">Rating</label>
            <fieldset class="starability-slot">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked
                aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>

          <div class="mb-3 mt-3">
            <label for="commment" class="form-label">Comments</label>
            <textarea required name="review[comment]" class="form-control" rows="4"></textarea>
            <div class="invalid-feedback">
              Please add some comment for review!
            </div>
          </div>
          <button class="btn btn-outline-dark">Submit</button>
        </form>

        <% } %>

          <hr>

          <% if(listing.reviews.length> 0) { %>
            <div class="row ">
              <p>All Reviews</p>
              <% for( review of listing.reviews){ %>
                <div class="card col-5 ms-4 mt-3 ">
                  <div class="card-body">
                    <h6 class="h6">@<%= review.author.username %>
                    </h6>
                    <p class="starability-result star-size" data-rating="<%= review.rating %>"></p>
                    <p class="card-text">
                      <%= review.comment %>
                    </p>
                  </div>
                  <form method="POST" action="/listings/<%=listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                    <% if(currUser) { %>
                    <button class="btn btn-dark mt-3 mb-3">Delete</button>
                     <% } %>
                  </form>
                </div>
                <% } %>
            </div>
            <% } %>
    </div>

    <script>
      const listingData = <%- JSON.stringify(listing) %>;
    </script>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

    <script>
      document.addEventListener("DOMContentLoaded", () => {

        const btn = document.getElementById("payBtn");

        if (!btn) {
          console.log("Button not found ❌");
          return;
        }

        btn.onclick = async function () {

          let checkIn = document.getElementById("checkin").value;
          let checkOut = document.getElementById("checkout").value;

          // validation
          if (new Date(checkOut) <= new Date(checkIn)) {
            alert("Checkout must be after checkin ❌");
            return;
          }

          // calculate price
          let nights = Math.ceil(
            (new Date(checkOut) - new Date(checkIn)) / (1000 * 60 * 60 * 24)
          );

          let amount = nights * listingData.price;
          console.log("Amount:", amount);

          try {

            let res = await fetch("/create-order", {
              method: "POST",
              headers: {
                "Content-Type": "application/json"
              },
              body: JSON.stringify({ amount })
            });

            let order = await res.json();

            new Razorpay({
              key: "<%= process.env.RAZORPAY_KEY_ID %>",
              amount: order.amount,
              currency: "INR",
              name: "Wanderlust",
              description: "Booking Payment",
              order_id: order.id,

              handler: async function (response) {

                await fetch("/success", {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/json"
                  },
                  body: JSON.stringify({
                    ...response,
                    listingId: listingData._id,
                    checkIn,
                    checkOut,
                    pricePerNight: listingData.price,
                    amount
                  })
                });

                Swal.fire({
                title: "Payment Successful 🎉",
                text: "Booking Confirmed!",
                icon: "success",
                confirmButtonColor: "#3085d6"
               }).then(() => {
                window.location.href = "/listings";
               });
              }

            }).open();

          } catch (err) {
            console.log(err);
            alert("Payment failed ❌");
          }

        };

      });
    </script>
      <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  </body>