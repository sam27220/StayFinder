<% layout("/layouts/boilerplate.ejs") %>

    <!-- booking -->
    <h2 class="mt-4 mb-3 fw-bold">My Bookings</h2>
    <% if(bookings.length===0) { %>

        <div class="text-center mt-5">
            <h4>No bookings yet!</h4>
            <p>Go and explore stays!</p>

            <a href="/listings" class="btn btn-primary mt-2">
                Browse Listings
            </a>
        </div>

        <% } else { %>


            <div class="row">
                <% bookings.forEach(b=> { %>
                    <div class="col-md-4 mb-4">
                        <div class="card booking-card h-100 shadow-sm">
                            <img src="<%= b.listing.image.url %>" class="card-img-top booking-img">
                            <div class="card-body">
                                <h5 class="fw-semibold">
                                    <%= b.listing.title %>
                                </h5>
                                <p class="text-muted small mb-2">
                                    Location: <%= b.listing.location %>
                                </p>

                                <div class="d-flex justify-content-between small">
                                    <span>Check-in</span>
                                    <span>Check-out</span>
                                </div>

                                <div class="d-flex justify-content-between mb-2">
                                    <b>
                                        <%= b.checkIn.toDateString() %>
                                    </b>
                                    <b>
                                        <%= b.checkOut.toDateString() %>
                                    </b>
                                </div>

                                <p class="mb-1">Nights: <b>
                                        <%= b.totalNights %>
                                    </b></p>

                                <p class="mb-2">
                                    Total: <b>₹ <%= b.amount %></b>
                                </p>

                                <!-- Status -->
                                <span class="badge 
                            <%= b.status === 'paid' ? 'bg-success' : 
                            b.status === 'cancelled' ? 'bg-danger' : 'bg-warning' %>">
                                    <%= b.status.toUpperCase() %>
                                </span>

                            </div>

                            <div class="card-body pt-0 mt-4">
                                <form action="/bookings/<%= b._id %>/cancel" method="POST">
                                    <button class="btn btn-outline-danger btn-sm">
                                        Cancel Booking
                                    </button>
                                </form>
                            </div>

                        </div>
                    </div>

                    <% }) %>

            </div>
            <% } %>