<% layout("/layouts/boilerplate.ejs") %>

<style>
    .policy-wrapper {
  background: #f7f7f7;
  min-height: 80vh;
  padding: 40px 10px;
}

.policy-card {
  max-width: 800px;
  margin: auto;
  background: white;
  padding: 30px 40px;
  border-radius: 15px;
  box-shadow: 0 5px 20px rgba(0,0,0,0.08);
}

.policy-card h1 {
  font-weight: 700;
  margin-bottom: 10px;
}

.subtitle {
  color: #666;
  margin-bottom: 25px;
}

.section {
  margin-bottom: 20px;
}

.section h4 {
  margin-bottom: 10px;
  color: #333;
}

.section ul {
  padding-left: 20px;
}
</style>

<div class="policy-wrapper">
  <div class="policy-card">

    <h1>Privacy Policy</h1>
    <p class="subtitle">
      Welcome to <strong>StayFinder</strong>. Your privacy is important to us.
    </p>

    <div class="section">
      <h4>1. Information We Collect</h4>
      <ul>
        <li>Username, email, and account details</li>
        <li>Booking and payment information</li>
        <li>Location and listing data</li>
      </ul>
    </div>

    <div class="section">
      <h4>2. How We Use Your Data</h4>
      <ul>
        <li>To manage bookings</li>
        <li>To improve user experience</li>
        <li>To process payments securely</li>
      </ul>
    </div>

    <div class="section">
      <h4>3. Data Protection</h4>
      <p>We do not sell your personal data. Payments are handled securely.</p>
    </div>

    <div class="section">
      <h4>4. Contact</h4>
      <p>Email: support@stayfinder.com</p>
    </div>

  </div>
</div>