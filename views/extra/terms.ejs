<% layout("/layouts/boilerplate.ejs") %>

    <style>
        .policy-wrapper {
            background: #f7f7f7;
            min-height: 80vh;
            padding: 40px 10px;
        }

        .policy-card {
            max-width: 800px;
            margin: auto;
            background: white;
            padding: 30px 40px;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        }

        .policy-card h1 {
            font-weight: 700;
        }

        .subtitle {
            color: #666;
            margin-bottom: 25px;
        }

        .section {
            margin-bottom: 20px;
        }
    </style>

    <div class="policy-wrapper">
        <div class="policy-card">

            <h1>Terms & Conditions</h1>
            <p class="subtitle">
                Please read these terms carefully before using <strong>StayFinder</strong>.
            </p>

            <div class="section">
                <h4>1. Acceptance of Terms</h4>
                <p>
                    By accessing StayFinder, you agree to comply with all terms and conditions.
                </p>
            </div>

            <div class="section">
                <h4>2. User Responsibilities</h4>
                <ul>
                    <li>Provide accurate information</li>
                    <li>Do not misuse the platform</li>
                    <li>Respect property owners</li>
                </ul>
            </div>

            <div class="section">
                <h4>3. Booking & Payments</h4>
                <ul>
                    <li>All bookings are subject to availability</li>
                    <li>Payments are processed securely via Razorpay</li>
                    <li>No fake bookings allowed</li>
                </ul>
            </div>

            <div class="section">
                <h4>4. Cancellation Policy</h4>
                <ul>
                    <li>Users can cancel bookings (based on rules)</li>
                    <li>Owners can cancel bookings</li>
                    <li>Status will be updated accordingly</li>
                </ul>
            </div>

            <div class="section">
                <h4>5. Liability</h4>
                <p>
                    StayFinder is not responsible for property-related issues or damages.
                </p>
            </div>

            <div class="section">
                <h4>6. Changes to Terms</h4>
                <p>
                    We may update these terms at any time without prior notice.
                </p>
            </div>

        </div>
    </div>